{
  "name": "dbui-src",
  "version": "0.2.0",
  "description": "DBUI Design System — Databricks component library built on shadcn/ui with DuBois design tokens",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "docs",
    "llms.txt",
    "composition.md",
    "CLAUDE.md",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./components/ui/*": "./src/components/ui/*.tsx",
    "./components/icons/*": "./src/components/icons/*.tsx",
    "./lib/*": "./src/lib/*",
    "./tokens/*": "./src/tokens/*",
    "./llms.txt": "./llms.txt"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/muditmittal/dbui.git",
    "directory": "packages/dbui"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./components/ui/*": {
        "import": "./dist/components/ui/*.js",
        "types": "./dist/components/ui/*.d.ts"
      },
      "./components/icons/*": "./src/components/icons/*.tsx",
      "./lib/*": {
        "import": "./dist/lib/*.js",
        "types": "./dist/lib/*.d.ts"
      },
      "./tokens/*": "./src/tokens/*",
      "./llms.txt": "./llms.txt"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "next-themes": ">=0.4",
    "react": ">=18",
    "react-dom": ">=18",
    "recharts": ">=2",
    "react-resizable-panels": ">=2",
    "tailwindcss": ">=4"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
